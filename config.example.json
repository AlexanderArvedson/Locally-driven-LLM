{
  "cron": "0 0 * * *",

  "system": {
    "context_path": "~/.graphify-system"
  },

  "repositories": [
    {
      "name": "example-repo",
      "url": "https://github.com/owner/repo.git",
      "base_branch": "main",
      "prefix": "AI-",
      "local_path": "/path/to/repo",

      "created_at": null,
      "updated_at": null,

      "max_workflow_revision_cycles": 3,
      "semantic_threshold": 0.75,

      "graph": {
        "mode": "hybrid",
        "auto_update": true
      },

      "retrieval": {
        "max_context_files": 20,
        "max_context_tokens": 12000,
        "limit_reached_behavior": "warn"
      },

      "planner": {
        "max_files": 3
      },

      "credentials": {
        "git": {
          "username": "",
          "token": ""
        }
      },

      "models": {
        "chat": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        },
        "coder": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        },
        "semantic_validator": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        },
        "describer": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": -1,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        },
        "reporter": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        },
        "embedding": {
          "name": "nomic-embed-text",
          "provider": "ollama",
          "api_key": null,
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300,
          "allow_gpu": true
        }
      },

      "pipeline": {
        "supported_languages": ["python", "typescript"],
        "ignore_paths": [".venv", "node_modules", "__pycache__", "dist", "build", ".git"],
        "similarity": {
          "threshold": 0.82,
          "top_n": 20,
          "code_weight": 0.70,
          "description_weight": 0.30
        },
        "concurrency": {
          "embed_code": 4,
          "embed_description": 4,
          "describe": 2
        },
        "batch_sizes": {
          "function_upsert": 50,
          "edge_upsert": 200
        },
        "limits": {
          "max_code_chars": 22000,
          "max_description_source_chars": 12000,
          "embedding_num_ctx": 8192,
          "context_overflow_char_threshold": 10000,
          "min_loc_threshold": 3
        },
        "test_patterns": ["tests/", "test_", "_test.py"],
        "include_tests_in_graph": false,
        "reporter": {
          "cluster_threshold": 0.92,
          "arch_coupling_threshold": 0.60,
          "test_pollution_threshold": 5,
          "timezone": "UTC",
          "top_n": 20,
          "max_embedding_failures": 200,
          "high_dup_min_cluster_size": 3,
          "high_dup_min_score": 0.95,
          "min_coupling_edges": 5,
          "max_coupling_files_listed": 5,
          "sim_dist_bin_high": 0.95,
          "sim_dist_bin_mid": 0.90,
          "sim_dist_bin_low": 0.80,
          "cohesion_low_threshold": 0.30,
          "cohesion_min_functions": 2,
          "max_cohesion_files_listed": 20,
          "max_isolated_listed": 50,
          "god_file_threshold": 20
        }
      }
    }
  ]
}
