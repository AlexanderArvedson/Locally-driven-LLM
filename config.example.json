{
  "cron": "0 0 * * *",

  "system": {
    "context_path": "~/.graphify-system"
  },

  "repositories": [
    {
      "name": "",
      "url": "https://github.com/owner/repo.git",
      "base_branch": "main",
      "prefix": "AI-",
      "local_path": "",

      "created_at": null,
      "updated_at": null,

      "max_iterations": 10,

      "graph": {
        "mode": "hybrid",
        "auto_update": true
      },

      "credentials": {
        "git": {
          "username": "",
          "token": ""
        }
      },

      "models": {
        "chat": {
          "name": "",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434"
        },
        "coder": {
          "name": "",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434"
        },
        "reviewer": {
          "name": "",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434"
        },
        "embedding": {
          "name": "",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434"
        }
      },

      "integrations": {
        "slack_webhook_url": null
      }
    }
  ]
}
