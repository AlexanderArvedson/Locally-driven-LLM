{
    "cron": "0 0 * * *",
    "repositories": [
        {
            "name": "your-repo-name",
            "url": "https://example.com/your-repo.git",
            "base_branch": "your-base-branch",
            "prefix": "your-prefix",
            "local_path": "/path/to/local/repo",
            "created_at": "creation timestamp",
            "updated_at": "last updated timestamp",
            "context_path": "/path/to/context",
            "max_iterations": "allowed iterations for workflows",
            "credentials": {
                "username": "your-username",
                "token": "your-token"
            },
            "models": {
                "LLM": {
                    "name": "your-llm-model",
                    "provider": "your-provider",
                    "api_key": null,
                    "url": "https://example.com/your-llm-endpoint"
                },
                "embedding": {
                    "name": "your-embedding-model",
                    "provider": "your-provider",
                    "api_key": null,
                    "url": "https://example.com/your-embedding-endpoint"
                }
            },
            "slack_webhook_url": "https://hooks.slack.com/services/your/webhook/url"
        }
    ]
}