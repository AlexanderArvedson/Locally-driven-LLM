{
  "cron": "0 0 * * *",

  "system": {
    "context_path": "~/.graphify-system"
  },

  "repositories": [
    {
      "name": "example-repo",
      "url": "https://github.com/owner/repo.git",
      "base_branch": "main",
      "prefix": "AI-",
      "local_path": "/path/to/repo",

      "created_at": null,
      "updated_at": null,

      "max_workflow_revision_cycles": 3,
      "semantic_threshold": 0.75,

      "graph": {
        "mode": "hybrid",
        "auto_update": true
      },

      "retrieval": {
        "max_context_files": 20,
        "max_context_tokens": 12000,
        "limit_reached_behavior": "warn"
      },

      "planner": {
        "max_files": 3
      },

      "credentials": {
        "git": {
          "username": "",
          "token": ""
        }
      },

      "models": {
        "chat": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434",
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300
        },
        "coder": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434",
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300
        },
        "semantic_validator": {
          "name": "qwen2.5-coder:7b",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434",
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300
        },
        "embedding": {
          "name": "nomic-embed-text",
          "provider": "ollama",
          "api_key": null,
          "url": "http://localhost:11434",
          "temperature": null,
          "max_tokens": null,
          "num_ctx": null,
          "timeout_seconds": 300
        }
      },

      "integrations": {
        "slack_webhook_url": null
      }
    }
  ]
}
