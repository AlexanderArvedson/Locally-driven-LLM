{
  "cron": "0 0 * * *",

  "system": {
    "context_path": "~/.graphify-system"
  },

  "repositories": [
    {
      "name": "Name of the repository",
      "url": "the url to the git repository",
      "base_branch": "main",
      "prefix": "DEV-AI-DATE-",
      "local_path": "absolute path to the local repository",

      "created_at": "timestamp",
      "updated_at": "timestamp",

      "max_iterations": 10,

      "graph": {
        "mode": "hybrid",
        "staleness_strategy": "sha_based",
        "auto_update": true
      },

      "credentials": {
        "git": {
          "username": "username",
          "token": "personal_access_token"
        }
      },

      "models": {
        "chat": {
          "name": "your-chat-model",
          "provider": "your-provider",
          "api_key": null,
          "url": "https://example.com/your-chat-model-endpoint"
        },
        "coder": {
          "name": "your-llm-model",
          "provider": "your-provider",
          "api_key": null,
          "url": "https://example.com/your-llm-endpoint"
        },
        "reviewer": {
          "name": "your-reviewer-model",
          "provider": "your-provider",
          "api_key": null,
          "url": "https://example.com/your-reviewer-endpoint"
        },
        "embedding": {
          "name": "your-embedding-model",
          "provider": "your-provider",
          "api_key": null,
          "url": "https://example.com/your-embedding-endpoint"
        }
      },

      "integrations": {
        "slack_webhook_url": "https://hooks.slack.com/services/your/webhook/url"
      }
    }
  ]
}