FROM python:3.12-slim

WORKDIR /app

# git is required by GitPython for the pre-flight repo sync.
# libpango/libharfbuzz/libcairo/libfontconfig are required by WeasyPrint for PDF generation.
# fonts-dejavu-core provides a baseline font set so PDFs render correctly.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    libpango-1.0-0 \
    libpangoft2-1.0-0 \
    libharfbuzz0b \
    libfontconfig1 \
    libcairo2 \
    libglib2.0-0 \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# trust all mounted directories — applies to all users, not just root
RUN git config --system --add safe.directory '*'

# install uv
RUN pip install --no-cache-dir uv

# copy dependency definitions first (for caching)
COPY pyproject.toml uv.lock* ./

# install dependencies from project definition into system site-packages
RUN uv pip install --system .

# copy application code
COPY . .

EXPOSE 8000

CMD ["python", "main.py"]