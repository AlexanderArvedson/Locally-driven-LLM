# Docker Compose reads .env automatically for ${VAR} substitution.
# Copy this file to .env and fill in the values for your setup.

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=60m
OLLAMA_NUM_PARALLEL=1

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

# --- Slack ---
# Bot token (xoxb-...) — OAuth & Permissions → Bot Token Scopes → commands
# Install the app to your workspace to generate this token.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token (xapp-1-...) — Basic Information → App-Level Tokens
# Required scope: connections:write
# Also enable Socket Mode under Settings → Socket Mode in your Slack app.
SLACK_APP_TOKEN=xapp-1-your-app-token-here

# Notification channel for pipeline completion (channel ID or #name).
# If unset, pipeline notifications are silently skipped.
SLACK_NOTIFY_CHANNEL=#deployments
