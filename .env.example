# Docker Compose reads .env automatically for ${VAR} substitution.
# Copy this file to .env and fill in the values for your setup.

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=60m
OLLAMA_NUM_PARALLEL=1

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

# --- Neo4j memory ---
# JVM heap and page cache allocated to the Neo4j container.
# Total RAM used is roughly NEO4J_HEAP_MAX_SIZE + NEO4J_PAGECACHE_SIZE.
# Reduce on machines with less than 4 GB free RAM (e.g. set both to 512m).
NEO4J_HEAP_INITIAL_SIZE=1G
NEO4J_HEAP_MAX_SIZE=1G
NEO4J_PAGECACHE_SIZE=512m

# --- Slack ---
# Bot token (xoxb-...) — OAuth & Permissions → Bot Token Scopes → commands
# Install the app to your workspace to generate this token.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token (xapp-1-...) — Basic Information → App-Level Tokens
# Required scope: connections:write
# Also enable Socket Mode under Settings → Socket Mode in your Slack app.
SLACK_APP_TOKEN=xapp-1-your-app-token-here

# Notification channel for pipeline completion (channel ID or #name).
# If unset, pipeline notifications are silently skipped.
SLACK_NOTIFY_CHANNEL=#deployments

# --- Repositories ---
# Parent directory that contains all repos listed in config.json.
# Mounted read-write into the fastapi container so the pipeline can clone repos on first run
# and pull updates on subsequent runs.
# Example: if local_path in config.json is /home/alice/projects/myrepo, set this to /home/alice/projects
REPOS_ROOT=/home/your-user/projects

# --- FastAPI ---
# Host port the FastAPI service listens on. Change if 8000 is already in use on your machine.
FASTAPI_PORT=8000

# --- Container user ---
# Run the fastapi container as your host user so files written to run_reports/
# are owned by you and can be deleted without sudo.
# Find your values with: id
UID=1000
GID=1000
